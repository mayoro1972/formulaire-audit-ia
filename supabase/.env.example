# Shared Supabase runtime values
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
FROM_EMAIL=Audit IA <noreply@example.com>
ADMIN_EMAIL=admin@example.com
GMAIL_FORWARD_ADDRESS=optional-forward@gmail.com

# EmailJS for invitation emails
EMAILJS_SERVICE_ID=service_xxxxxxx
EMAILJS_TEMPLATE_ID=template_xxxxxxx
EMAILJS_PUBLIC_KEY=public_xxxxxxx
EMAILJS_PRIVATE_KEY=private_xxxxxxx

# EmailJS for form return emails (fallback when Resend fails)
# If not set, falls back to EMAILJS_SERVICE_ID / EMAILJS_TEMPLATE_ID above
EMAILJS_RETURN_SERVICE_ID=service_xxxxxxx
EMAILJS_RETURN_TEMPLATE_ID=template_xxxxxxx
